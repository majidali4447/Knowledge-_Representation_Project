  <owl:NamedIndividual rdf:about="http://www.semanticweb.org/culturalheritage-museum#MonaLisaScan01">
    <rdf:type rdf:resource="http://www.semanticweb.org/culturalheritage-museum#ThreeDScan"/>
    <archivedIn rdf:resource="http://www.semanticweb.org/culturalheritage-museum#DigitalArchive01"/>
    <documents>
      <owl:NamedIndividual rdf:about="http://www.semanticweb.org/culturalheritage-museum#MonaLisa">
        <rdf:type rdf:resource="http://www.semanticweb.org/culturalheritage-museum#Painting"/>
        <associatedWithPeriod rdf:resource="http://www.semanticweb.org/culturalheritage-museum#Renaissance"/>
        <displayedIn rdf:resource="http://www.semanticweb.org/culturalheritage-museum#LouvreMuseum"/>
        <hasCreator rdf:resource="http://www.semanticweb.org/culturalheritage-museum#LeonardoDaVinci"/>
        <madeOf rdf:resource="http://www.semanticweb.org/culturalheritage-museum#CanvasMaterial"/>
        <usesTechnique rdf:resource="http://www.semanticweb.org/culturalheritage-museum#OilPainting"/>
        <creationDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1503-01-01</creationDate>
        <hasTitle>Mona Lisa</hasTitle>
        <inventoryNumber>CHMO-ART-002</inventoryNumber>
        <rdfs:label>Mona Lisa</rdfs:label>
      </owl:NamedIndividual>
    </documents>
    <fileFormat>OBJ</fileFormat>
