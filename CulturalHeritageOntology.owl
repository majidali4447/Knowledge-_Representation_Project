  <owl:NamedIndividual rdf:about="http://www.semanticweb.org/culturalheritage-museum#StarryNightImage01">
    <rdf:type rdf:resource="http://www.semanticweb.org/culturalheritage-museum#Image"/>
    <archivedIn>
      <owl:NamedIndividual rdf:about="http://www.semanticweb.org/culturalheritage-museum#DigitalArchive01">
        <rdf:type rdf:resource="http://www.semanticweb.org/culturalheritage-museum#DigitalRepository"/>
        <archiveCode>DA-001</archiveCode>
        <rdfs:label>Digital Archive01</rdfs:label>
      </owl:NamedIndividual>
    </archivedIn>
    <documents>
      <owl:NamedIndividual rdf:about="http://www.semanticweb.org/culturalheritage-museum#TheStarryNight">
        <rdf:type rdf:resource="http://www.semanticweb.org/culturalheritage-museum#Painting"/>
        <associatedWithPeriod rdf:resource="http://www.semanticweb.org/culturalheritage-museum#PostImpressionism"/>
        <displayedIn rdf:resource="http://www.semanticweb.org/culturalheritage-museum#MuseumOfModernArt"/>
        <hasCreator rdf:resource="http://www.semanticweb.org/culturalheritage-museum#VincentVanGogh"/>
        <madeOf rdf:resource="http://www.semanticweb.org/culturalheritage-museum#CanvasMaterial"/>
        <usesTechnique rdf:resource="http://www.semanticweb.org/culturalheritage-museum#OilPainting"/>
        <creationDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1889-01-01</creationDate>
        <hasTitle>The Starry Night</hasTitle>
        <inventoryNumber>CHMO-ART-001</inventoryNumber>
        <rdfs:label>The Starry Night</rdfs:label>
      </owl:NamedIndividual>
    </documents>
    <fileFormat>JPEG</fileFormat>
    <scanResolution>6000x4000</scanResolution>
    <rdfs:label>Starry Night Image01</rdfs:label>
  </owl:NamedIndividual>
