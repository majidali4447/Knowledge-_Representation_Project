<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/culturalheritage-museum#"
     xml:base="http://www.semanticweb.org/culturalheritage-museum"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">

    <owl:Ontology rdf:about="http://www.semanticweb.org/culturalheritage-museum">
        <rdfs:comment>Cultural Heritage and Museum Ontology developed in OWL 2 using Protégé.</rdfs:comment>
        <rdfs:label>Cultural Heritage and Museum Ontology</rdfs:label>
    </owl:Ontology>

    <!--
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
    -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#hasCreator">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/culturalheritage-museum#createdBy"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/culturalheritage-museum#CulturalHeritageObject"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/culturalheritage-museum#Artist"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#createdBy">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/culturalheritage-museum#CulturalHeritageObject"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/culturalheritage-museum#Artist"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#displayedIn">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/culturalheritage-museum#CulturalHeritageObject"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/culturalheritage-museum#Museum"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#belongsToCollection">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/culturalheritage-museum#hasCollectionMember"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/culturalheritage-museum#CulturalHeritageObject"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/culturalheritage-museum#Collection"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#hasCollectionMember">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/culturalheritage-museum#Collection"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/culturalheritage-museum#CulturalHeritageObject"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#curatedBy">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/culturalheritage-museum#Exhibition"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/culturalheritage-museum#Curator"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#organizedBy">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/culturalheritage-museum#Exhibition"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/culturalheritage-museum#Museum"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#locatedIn">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/culturalheritage-museum#Location"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/culturalheritage-museum#Location"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#currentlyLocatedIn">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/culturalheritage-museum#CulturalHeritageObject"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/culturalheritage-museum#Location"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#associatedWithPeriod">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/culturalheritage-museum#CulturalHeritageObject"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/culturalheritage-museum#HistoricalPeriod"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#madeOf">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/culturalheritage-museum#CulturalHeritageObject"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/culturalheritage-museum#Material"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#usesTechnique">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/culturalheritage-museum#CulturalHeritageObject"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/culturalheritage-museum#Technique"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#documentedIn">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/culturalheritage-museum#documents"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/culturalheritage-museum#CulturalHeritageObject"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/culturalheritage-museum#MediaObject"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#documents">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/culturalheritage-museum#MediaObject"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/culturalheritage-museum#CulturalHeritageObject"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#restoredBy">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/culturalheritage-museum#RestorationEvent"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/culturalheritage-museum#Conservator"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#restoresObject">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/culturalheritage-museum#RestorationEvent"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/culturalheritage-museum#CulturalHeritageObject"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#archivedIn">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/culturalheritage-museum#MediaObject"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/culturalheritage-museum#DigitalRepository"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#digitizedBy">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/culturalheritage-museum#CulturalHeritageObject"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/culturalheritage-museum#Device"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#preservedBy">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/culturalheritage-museum#CulturalHeritageObject"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/culturalheritage-museum#Conservator"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#discoveredAt">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/culturalheritage-museum#CulturalHeritageObject"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/culturalheritage-museum#ArchaeologicalSite"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#exhibitedAt">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/culturalheritage-museum#CulturalHeritageObject"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/culturalheritage-museum#Exhibition"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#loanedTo">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/culturalheritage-museum#loanedFrom"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#loanedFrom"/>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#inspiredBy"/>
    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#influencedBy"/>
    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#represents"/>
    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#depicts"/>
    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#owns"/>
    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#manages"/>
    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#references"/>
    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#citedIn"/>
    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#participatesInExhibition"/>
    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#supervisedBy"/>
    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#evaluatedBy"/>
    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#captures"/>
    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#storedIn"/>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#relatedToEvent">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/culturalheritage-museum#Event"/>
    </owl:ObjectProperty>

    <!--
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
    -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#hasTitle">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#hasDescription">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#inventoryNumber">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#accessionNumber">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#archiveCode">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#creationDate">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#acquisitionDate">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#discoveryDate">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#restorationDate">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#publicationYear">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#gYear"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#restorationCost">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#height">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#width">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#depth">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#weight">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#conditionStatus">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#conservationLevel">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#materialType">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#techniqueName">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#estimatedValue">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#fileFormat">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#scanResolution">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#creatorName">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#birthYear">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#gYear"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#deathYear">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#gYear"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#museumName">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/culturalheritage-museum#countryName">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <!--
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
    -->

    <owl:Class rdf:about="http://www.semanticweb.org/culturalheritage-museum#Agent"/>

    <owl:Class rdf:about="http://www.semanticweb.org/culturalheritage-museum#Person">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/culturalheritage-museum#Agent"/>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/culturalheritage-museum#Organization">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/culturalheritage-museum#Agent"/>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/culturalheritage-museum#Artist">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/culturalheritage-museum#Person"/>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/culturalheritage-museum#Curator">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/culturalheritage-museum#Person"/>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/culturalheritage-museum#Visitor">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/culturalheritage-museum#Person"/>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/culturalheritage-museum#Researcher">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/culturalheritage-museum#Person"/>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/culturalheritage-museum#Conservator">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/culturalheritage-museum#Person"/>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/culturalheritage-museum#Collector">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/culturalheritage-museum#Person"/>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/culturalheritage-museum#Museum">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/culturalheritage-museum#Organization"/>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/culturalheritage-museum#Gallery">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/culturalheritage-museum#Organization"/>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/culturalheritage-museum#CulturalInstitution">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/culturalheritage-museum#Organization"/>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/culturalheritage-museum#CulturalHeritageObject">
        <rdfs:comment>A physical or digital object with cultural, artistic, historical, or archaeological value.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/culturalheritage-museum#Artifact">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/culturalheritage-museum#CulturalHeritageObject"/>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/culturalheritage-museum#Artwork">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/culturalheritage-museum#CulturalHeritageObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/culturalheritage-museum#hasCreator"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/culturalheritage-museum#Artist"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/culturalheritage-museum#Painting">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/culturalheritage-museum#Artwork"/>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/culturalheritage-museum#Sculpture">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/culturalheritage-museum#Artwork"/>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/culturalheritage-museum#Manuscript">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/culturalheritage-museum#CulturalHeritageObject"/>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/culturalheritage-museum#Coin">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/culturalheritage-museum#Artifact"/>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/culturalheritage-museum#Textile">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/culturalheritage-museum#Artifact"/>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/culturalheritage-museum#CeramicObject">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/culturalheritage-museum#Artifact"/>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/culturalheritage-museum#ArchaeologicalObject">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/culturalheritage-museum#Artifact"/>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/culturalheritage-museum#HeritageSite">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/culturalheritage-museum#Location"/>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/culturalheritage-museum#Collection"/>
    <owl:Class rdf:about="http://www.semanticweb.org/culturalheritage-museum#PermanentCollection">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/culturalheritage-museum#Collection"/>
    </owl:Class>
    <owl:Class rdf:about="http://www.semanticweb.org/culturalheritage-museum#TemporaryCollection">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/culturalheritage-museum#Collection"/>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/culturalheritage-museum#Exhibition">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/culturalheritage-museum#organizedBy"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/culturalheritage-museum#Museum"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    <owl:Class rdf:about="http://www.semanticweb.org/culturalheritage-museum#PermanentExhibition">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/culturalheritage-museum#Exhibition"/>
    </owl:Class>
    <owl:Class rdf:about="http://www.semanticweb.org/culturalheritage-museum#TemporaryExhibition">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/culturalheritage-museum#Exhibition"/>
    </owl:Class>
    <owl:Class rdf:about="http://www.semanticweb.org/culturalheritage-museum#OnlineExhibition">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/culturalheritage-museum#Exhibition"/>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/culturalheritage-museum#Archive">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/culturalheritage-museum#Organization"/>
    </owl:Class>
    <owl:Class rdf:about="http://www.semanticweb.org/culturalheritage-museum#DigitalRepository">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/culturalheritage-museum#Archive"/>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/culturalheritage-museum#HistoricalPeriod"/>
    <owl:Class rdf:about="http://www.semanticweb.org/culturalheritage-museum#Event"/>
